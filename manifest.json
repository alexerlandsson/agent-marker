{
  "manifest_version": 3,
  "name": "Agent Marker",
  "version": "0.2.1",
  "description": "Mark elements on a page, write what should change, and send the batch to an AI coding agent.",
  "minimum_chrome_version": "110",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle Agent Marker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/geist.woff2", "fonts/geist-mono.woff2"],
      "matches": ["<all_urls>"]
    }
  ]
}
